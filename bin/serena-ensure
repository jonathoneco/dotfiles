#!/usr/bin/env bash
# Ensure a shared Serena HTTP MCP server is running for a project directory.
# Usage: serena-ensure [project-dir]   # defaults to $PWD

set -euo pipefail

SERENA_DIR="$HOME/.serena"
PORTS_CONF="$SERENA_DIR/ports.conf"
PIDS_DIR="$SERENA_DIR/pids"
LOGS_DIR="$SERENA_DIR/logs"
BASE_PORT=9710

# Use mise latest symlinks for stable PATH
MISE_PATH="/home/jonco/.local/share/mise/installs/go/latest/bin"
MISE_PATH="$MISE_PATH:/home/jonco/.local/share/mise/installs/node/latest/bin"
MISE_PATH="$MISE_PATH:/home/jonco/.local/share/mise/installs/python/latest/bin"
SERENA_PATH="$MISE_PATH:/home/jonco/.cargo/bin:/home/jonco/.local/bin:/home/jonco/bin:/usr/local/bin:/usr/bin:/usr/sbin"

# --- Language detection ---

detect_languages() {
    local dir="$1"
    local langs=""

    [ -f "$dir/go.mod" ] && langs="${langs:+$langs, }go"
    [ -f "$dir/package.json" ] && langs="${langs:+$langs, }typescript"
    { [ -f "$dir/pyproject.toml" ] || [ -f "$dir/setup.py" ] || [ -f "$dir/requirements.txt" ]; } && langs="${langs:+$langs, }python"
    [ -f "$dir/Cargo.toml" ] && langs="${langs:+$langs, }rust"

    if ls "$dir"/*.lua 1>/dev/null 2>&1 || [ -d "$dir/lua" ]; then
        langs="${langs:+$langs, }lua"
    fi

    echo "$langs"
}

# --- Project config generation ---

ensure_project_yml() {
    local dir="$1"
    local yml="$dir/.serena/project.yml"

    local project_name
    project_name="$(basename "$dir")"

    # If config exists, update project_name if it changed (worktree directory names vary)
    if [ -f "$yml" ]; then
        local current_name
        current_name="$(sed -n 's/^project_name: *"\{0,1\}\([^"]*\)"\{0,1\}$/\1/p' "$yml")"
        if [ "$current_name" != "$project_name" ] && [ -n "$current_name" ]; then
            sed -i "s/^project_name: .*/project_name: \"$project_name\"/" "$yml"
        fi
        return 0
    fi

    local detected
    detected="$(detect_languages "$dir")"

    mkdir -p "$dir/.serena"

    # Build YAML languages array
    local lang_lines=""
    if [ -n "$detected" ]; then
        # Split comma-separated into YAML list items
        lang_lines="$(echo "$detected" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | sed 's/^/  - /')"
    fi

    cat > "$yml" << YAML
project_name: "$project_name"
languages:
${lang_lines:-"  []"}
encoding: utf-8
use_gitignore: true
read_only: false
excluded_tools:
  - list_dir
  - find_file
  - search_for_pattern
  - think_about_collected_information
  - think_about_task_adherence
  - think_about_whether_you_are_done
  - summarize_changes
  - get_current_config
YAML
}

# Resolve project directory
PROJECT_DIR="$(cd "${1:-$PWD}" && pwd)"

# Ensure project has Serena config
ensure_project_yml "$PROJECT_DIR"

# Ensure directories exist
mkdir -p "$PIDS_DIR" "$LOGS_DIR"
touch "$PORTS_CONF"

# --- Port registry ---

get_port() {
    awk -F= -v dir="$PROJECT_DIR" '$1 == dir {print $2; exit}' "$PORTS_CONF" 2>/dev/null
}

next_port() {
    local max_port
    max_port=$(awk -F= '{print $2}' "$PORTS_CONF" 2>/dev/null | sort -n | tail -1)
    echo $(( ${max_port:-$(( BASE_PORT - 1 ))} + 1 ))
}

assign_port() {
    local port
    port="$(next_port)"
    echo "${PROJECT_DIR}=${port}" >> "$PORTS_CONF"
    echo "$port"
}

PORT="$(get_port)"
if [ -z "$PORT" ]; then
    PORT="$(assign_port)"
fi

PID_FILE="$PIDS_DIR/${PORT}.pid"
LOG_FILE="$LOGS_DIR/${PORT}.log"

# --- Health check ---

is_running() {
    # Check PID file exists and process is alive
    if [ -f "$PID_FILE" ]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        # Stale PID file
        rm -f "$PID_FILE"
    fi
    return 1
}

health_check() {
    curl -sf -o /dev/null --max-time 2 "http://localhost:${PORT}/mcp" 2>/dev/null
}

# --- Start server if needed ---

if is_running && health_check; then
    : # Server already running and healthy
else
    # Kill stale process if PID exists but health check fails
    if [ -f "$PID_FILE" ]; then
        kill "$(cat "$PID_FILE")" 2>/dev/null || true
        rm -f "$PID_FILE"
    fi

    # Start Serena in the background
    PATH="$SERENA_PATH" \
    nohup uvx --from "git+https://github.com/oraios/serena" \
        serena start-mcp-server \
        --context=claude-code \
        --project-from-cwd \
        --transport=streamable-http \
        "--port=${PORT}" \
        > "$LOG_FILE" 2>&1 &

    echo $! > "$PID_FILE"

    # Wait briefly for server to become ready
    for _ in 1 2 3 4 5; do
        sleep 1
        if health_check; then
            break
        fi
    done
fi

# --- Update .mcp.json ---

MCP_JSON="${PROJECT_DIR}/.mcp.json"
SERENA_ENTRY="{\"mcpServers\":{\"serena\":{\"type\":\"streamable-http\",\"url\":\"http://localhost:${PORT}/mcp\"}}}"

if [ -f "$MCP_JSON" ]; then
    # Merge serena entry into existing .mcp.json (preserving other servers)
    TMP="$(mktemp)"
    jq --argjson new "$SERENA_ENTRY" '.mcpServers.serena = $new.mcpServers.serena' "$MCP_JSON" > "$TMP" \
        && mv "$TMP" "$MCP_JSON"
else
    echo "$SERENA_ENTRY" | jq '.' > "$MCP_JSON"
fi

# Extract project name and languages for activation context
PROJECT_NAME="$(basename "$PROJECT_DIR")"
DETECTED_LANGS="$(detect_languages "$PROJECT_DIR")"

echo "Serena MCP server active for ${PROJECT_NAME} (languages: ${DETECTED_LANGS:-none})."
echo "Run /serena-activate to initialize semantic code navigation tools."
