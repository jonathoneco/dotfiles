#!/usr/bin/env bash
# tmux-open - Pick URLs or file paths from the tmux pane via fzf
#   URLs    → the platform's default opener
#   Files   → nvim in a tmux popup (cwd = pane's working directory)
#
# Fixes URLs broken by soft-wrap (capture-pane -J) and hard-wrap
# (perl line-joining heuristic). Detects file paths with optional
# :line:col suffixes and verifies they exist on disk.

set -euo pipefail

trim_trailing_path_junk() {
    local value="$1"
    local result_var="$2"
    local last

    while [[ -n "$value" ]]; do
        last="${value: -1}"
        case "$last" in
            [[:space:]]|'.'|','|';'|':'|'!'|'?'|')'|'>'|'"'|"'")
                value="${value%?}"
                ;;
            *)
                break
                ;;
        esac
    done

    printf -v "$result_var" '%s' "$value"
}

main() {
    local pane_path
    pane_path=$(tmux display-message -p '#{pane_current_path}')

    # -J joins soft-wrapped lines (fixes URLs broken by terminal wrapping)
    # -p prints to stdout
    # Keep the recent scrollback bounded so candidate extraction stays fast.
    # This is enough to include the current command and its recent output.
    # No -e: plain text avoids escape sequences interfering with matching
    local content
    content=$(tmux capture-pane -J -p -S -500)

    # Rejoin URLs split across hard newlines: when an http(s) URL reaches
    # end-of-line and the next line continues without leading whitespace
    content=$(printf '%s\n' "$content" | perl -0777 -pe \
        's{(https?://\S+)\n(\S)}{$1$2}g')

    local -a items=()

    # --- URLs ---
    local urls

    # Protocol-prefixed URLs
    urls=$(printf '%s\n' "$content" \
        | perl -nle 'while (m{(?:https?|ftp|file)://[^\s<>"\x27{}|]+}g) { print $& }' \
        | sed -E 's/[).,;:!?"]+$//' \
        | sort -u) || true

    # Bare domains: www.* or multi-dot hostnames (e.g. vjw.digital.go.jp)
    # with optional path. Prepend https://.
    local bare
    bare=$(printf '%s\n' "$content" \
        | perl -nle 'while (m{(?<!\S)(?:www\.[a-zA-Z0-9][-a-zA-Z0-9]*(?:\.[a-zA-Z0-9][-a-zA-Z0-9]*)+|[a-zA-Z0-9][-a-zA-Z0-9]*(?:\.[a-zA-Z0-9][-a-zA-Z0-9]*){2,})(/[^\s<>"\x27{}|]*)?(?!\S)}g) { print $& }' \
        | sed -E 's/[).,;:!?"]+$//' \
        | sort -u) || true

    # Merge, dedup, and tag
    local all_urls
    all_urls=$(printf '%s\n' "$urls" "$bare" | grep -v '^$' | sort -u) || true

    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        if [[ "$url" != *://* ]]; then
            items+=("URL  https://${url}")
        else
            items+=("URL  ${url}")
        fi
    done <<< "$all_urls"

    # --- File paths ---
    # Strip URLs so path regex doesn't match inside them
    local content_no_urls
    content_no_urls=$(printf '%s\n' "$content" \
        | sed -E 's#(https?|ftp|file)://[^[:space:]]+##g')

    # Strict pass: paths without spaces (catches bare relative paths like
    # src/main.go that lack an explicit prefix).
    local strict_cands
    strict_cands=$(printf '%s\n' "$content_no_urls" \
        | grep -oE '(~/|\.{0,2}/)?[A-Za-z0-9_.@-]+(/[A-Za-z0-9_.@-]+)+(:[0-9]+){0,2}' \
        | sort -u) || true

    # Also recognize document/source filenames without a directory prefix,
    # such as README.md or config.yaml, when they exist in the pane's cwd.
    local bare_file_cands
    bare_file_cands=$(printf '%s\n' "$content_no_urls" \
        | perl -nle 'while (m{(?<![A-Za-z0-9_./-])[A-Za-z0-9_.@-]+\.(?:md|markdown|txt|json|ya?ml|toml|xml|html?|css|scss|js|jsx|ts|tsx|go|rs|py|rb|sh|zsh|fish|lua|vim|conf|service|timer|log|csv|sql|c|h|cc|cpp|java)(?::[0-9]+){0,2}}g) { print $& }' \
        | sort -u) || true

    # Broad pass: paths with embedded spaces. Anchored at a path-prefix
    # (/, ~/, ./, ../) preceded by a word boundary so we don't gobble
    # leading prose. Progressive truncation below trims trailing junk.
    local broad_cands
    broad_cands=$(printf '%s\n' "$content_no_urls" \
        | perl -nle 'while (m{(?:^|[\s([<"\x27])\K(?:~/|\.{0,2}/|/)[A-Za-z0-9_.@-][A-Za-z0-9_.@ -]*(?:/[A-Za-z0-9_.@-][A-Za-z0-9_.@ -]*)+(?::[0-9]+){0,2}}g) { print $& }' \
        | sort -u) || true

    local candidates
    candidates=$(printf '%s\n%s\n%s\n' "$strict_cands" "$bare_file_cands" "$broad_cands" \
        | grep -v '^$' | sort -u)

    while IFS= read -r candidate; do
        [[ -z "$candidate" ]] && continue

        local file_part="$candidate"
        local line_part=""
        if [[ "$file_part" =~ :([0-9]+)(:[0-9]+)?$ ]]; then
            line_part="${BASH_REMATCH[1]}"
            file_part="${file_part%"${BASH_REMATCH[0]}"}"
        fi

        # Progressive truncation: try the full candidate, then drop the
        # last whitespace-separated word until we find an existing file
        # (or run out of words). Handles paths with embedded spaces.
        local resolved=""
        local try="$file_part"
        while [[ -n "$try" ]]; do
            trim_trailing_path_junk "$try" try
            [[ -z "$try" ]] && break

            local full_path
            # shellcheck disable=SC2088
            case "$try" in
                "~/"*) full_path="${HOME}/${try#\~/}" ;;
                /*)    full_path="$try" ;;
                *)     full_path="${pane_path}/${try}" ;;
            esac
            if [[ -f "$full_path" ]]; then
                resolved="$full_path"
                break
            fi

            local shorter="${try% *}"
            [[ "$shorter" == "$try" ]] && break
            try="$shorter"
        done

        if [[ -n "$resolved" ]]; then
            if [[ -n "${line_part:-}" ]]; then
                items+=("FILE ${resolved}:${line_part}")
            else
                items+=("FILE ${resolved}")
            fi
        fi
    done <<< "$candidates"

    if [[ ${#items[@]} -eq 0 ]]; then
        tmux display-message 'No URLs or file paths found'
        return 0
    fi

    # Prefer the standard Linux opener, then the macOS opener, then GLib's
    # cross-desktop fallback. Keep the command as an array because `gio open`
    # has an extra subcommand while the other openers do not.
    local -a opener=()
    if command -v xdg-open >/dev/null 2>&1; then
        opener=(xdg-open)
    elif command -v open >/dev/null 2>&1; then
        opener=(open)
    elif command -v gio >/dev/null 2>&1; then
        opener=(gio open)
    fi

    # --- fzf selection ---
    # fzf selection — enter: default action, ctrl-g: open file in new pane
    local fzf_opts="--multi --exit-0 --no-preview --expect=ctrl-g,ctrl-y"
    fzf_opts+=" --header='enter: open (prefix+d in popup → promote to window) | ctrl-g: new window | ctrl-y: copy'"
    local fzf_cmd
    if fzf --version 2>/dev/null | awk '{exit ($1 < "0.53.0")}'; then
        fzf_cmd="fzf --tmux center,100%,50% $fzf_opts"
    else
        fzf_cmd="fzf-tmux -w 100% -h 50% $fzf_opts"
    fi

    local selected
    selected=$(printf '%s\n' "${items[@]}" | eval "$fzf_cmd") || return 0

    # First line from --expect is the key pressed (empty = enter)
    local key
    key=$(head -1 <<< "$selected")
    selected=$(tail -n +2 <<< "$selected")

    # ctrl-y: copy selected items to clipboard and stop
    if [[ "$key" == "ctrl-y" ]]; then
        local copy_text=""
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local target
            target="${line#* }"
            target="${target#"${target%%[! ]*}"}"
            [[ -n "$copy_text" ]] && copy_text+=$'\n'
            copy_text+="$target"
        done <<< "$selected"
        printf '%s' "$copy_text" | tmux load-buffer -
        tmux display-message "Copied: ${copy_text}"
        return 0
    fi

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local type target
        type="${line%% *}"
        target="${line#* }"
        target="${target#"${target%%[! ]*}"}"

        case "$type" in
            URL)
                if [[ ${#opener[@]} -eq 0 ]]; then
                    tmux display-message 'No platform opener found (tried xdg-open, open, gio)'
                    return 1
                fi
                nohup "${opener[@]}" "$target" >/dev/null 2>&1 &
                disown
                ;;
            FILE)
                local filepath lineno
                filepath="${target%%:*}"
                lineno="${target#*:}"
                [[ "$lineno" == "$target" ]] && lineno=""

                local mime
                mime=$(file -b --mime-type "$filepath")

                case "$mime" in
                text/*|application/json|application/javascript|application/xml|application/x-shellscript|application/x-yaml|application/toml)
                    local nvim_args=()
                    [[ -n "$lineno" ]] && nvim_args+=("+${lineno}")
                    nvim_args+=("$filepath")
                    if [[ "$key" == "ctrl-g" ]]; then
                        tmux new-window -c "$pane_path" nvim "${nvim_args[@]}"
                    else
                        # Promotable popup via shared wrapper — prefix+d inside
                        # the popup promotes it to a new tmux window.
                        tmux-popup -d "$pane_path" nvim "${nvim_args[@]}"
                    fi
                    ;;
                image/*)
                    if [[ ${#opener[@]} -eq 0 ]]; then
                        tmux display-message 'No platform opener found (tried xdg-open, open, gio)'
                        return 1
                    fi
                    nohup "${opener[@]}" "$filepath" >/dev/null 2>&1 &
                    disown
                    ;;
                *)
                    if [[ ${#opener[@]} -eq 0 ]]; then
                        tmux display-message 'No platform opener found (tried xdg-open, open, gio)'
                        return 1
                    fi
                    nohup "${opener[@]}" "$filepath" >/dev/null 2>&1 &
                    disown
                    ;;
                esac

                ;;
        esac
    done <<< "$selected"
}

main
