#!/usr/bin/env bash
# herdr-open - Pick URLs or file paths from the focused Herdr pane via fzf.
# URLs open with macOS `open`; files open in a new Herdr tab running Neovim.
set -euo pipefail

main() {
    local herdr_bin=${HERDR_BIN_PATH:-herdr}
    local pane_id=${HERDR_ACTIVE_PANE_ID:?HERDR_ACTIVE_PANE_ID is required}
    local workspace_id=${HERDR_ACTIVE_WORKSPACE_ID:?HERDR_ACTIVE_WORKSPACE_ID is required}
    local pane_path=${HERDR_ACTIVE_PANE_CWD:-$PWD}

    # recent-unwrapped joins soft-wrapped terminal lines. Keep a generous
    # window so the picker covers the configured 10 MiB scrollback limit.
    local content
    content=$("$herdr_bin" pane read "$pane_id" --source recent-unwrapped --lines 100000)

    # Rejoin URLs split across hard newlines when the following line continues
    # without leading whitespace.
    content=$(printf '%s\n' "$content" | perl -0777 -pe \
        's{(https?://\S+)\n(\S)}{$1$2}g')

    local -a items=()
    local urls bare all_urls url

    urls=$(printf '%s\n' "$content" | perl -ne '
        while (m{((?:https?|ftp|file)://[^\s<>"\x27{}|]+)}g) {
            my $url = $1;
            $url =~ s/[).,;:!?"]+$//;
            print "$url\n";
        }
    ' | sort -u) || true

    bare=$(printf '%s\n' "$content" | perl -ne '
        while (m{(?<!\S)((?:www\.[A-Za-z0-9][A-Za-z0-9-]*(?:\.[A-Za-z0-9][A-Za-z0-9-]*)+|[A-Za-z0-9][A-Za-z0-9-]*(?:\.[A-Za-z0-9][A-Za-z0-9-]*){2,})(?:/[^\s<>"\x27{}|]*)?)(?!\S)}g) {
            my $url = $1;
            $url =~ s/[).,;:!?"]+$//;
            print "$url\n";
        }
    ' | sort -u) || true

    all_urls=$(printf '%s\n' "$urls" "$bare" | sed '/^$/d' | sort -u) || true
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        [[ "$url" == *://* ]] || url="https://${url}"
        items+=("URL"$'\t'"${url}"$'\t')
    done <<< "$all_urls"

    # Remove URLs before extracting paths, so URL path components do not show
    # up as false file candidates.
    local content_no_urls strict_cands broad_cands candidates candidate
    content_no_urls=$(printf '%s\n' "$content" | perl -pe \
        's{(?:https?|ftp|file)://[^\s]+}{}g')

    strict_cands=$(printf '%s\n' "$content_no_urls" | perl -ne '
        while (m{((?:~/|\./|\.\./)?[A-Za-z0-9_.@-]+(?:/[A-Za-z0-9_.@-]+)+(?:\:[0-9]+){0,2})}g) {
            print "$1\n";
        }
    ' | sort -u) || true

    broad_cands=$(printf '%s\n' "$content_no_urls" | perl -ne '
        while (m{(?:^|[\s\[\(<"\x27])((?:~/|\./|\.\./|/)[A-Za-z0-9_.@-][A-Za-z0-9_.@ -]*(?:/[A-Za-z0-9_.@-][A-Za-z0-9_.@ -]*)+(?::[0-9]+){0,2})}g) {
            print "$1\n";
        }
    ' | sort -u) || true

    candidates=$(printf '%s\n%s\n' "$strict_cands" "$broad_cands" | sed '/^$/d' | sort -u)
    while IFS= read -r candidate; do
        [[ -z "$candidate" ]] && continue

        local file_part line_part try full_path resolved
        local last_component prefix prior_component
        file_part="$candidate"
        line_part=""
        last_component=${candidate##*:}
        if [[ "$last_component" =~ ^[0-9]+$ ]]; then
            prefix=${candidate%:*}
            prior_component=${prefix##*:}
            if [[ "$prior_component" =~ ^[0-9]+$ ]]; then
                file_part=${prefix%:*}
                line_part="$prior_component"
            else
                file_part="$prefix"
                line_part="$last_component"
            fi
        fi
        resolved=""
        try="$file_part"

        # Trim prose/punctuation from broad candidates until an existing file
        # resolves. The path is already absolute after joining it to pane_path,
        # so an existence check avoids a subprocess for each candidate.
        while [[ -n "$try" ]]; do
            case "${try: -1}" in
                [[:space:]]|.|,|';'|:|'!'|'?'|')'|'>'|'"'|"'") try=${try%?} ;;
                *) break ;;
            esac
            [[ -z "$try" ]] && break

            # shellcheck disable=SC2088 # literal tilde pattern
            case "$try" in
                "~/"*) full_path="${HOME}/${try#\~/}" ;;
                /*)  full_path="$try" ;;
                *)   full_path="${pane_path}/${try}" ;;
            esac

            if [[ -f "$full_path" ]]; then
                resolved="$full_path"
                break
            fi

            local shorter="${try% *}"
            [[ "$shorter" == "$try" ]] && break
            try="$shorter"
        done

        if [[ -n "$resolved" ]]; then
            items+=("FILE"$'\t'"${resolved}"$'\t'"${line_part}")
        fi
    done <<< "$candidates"

    if [[ ${#items[@]} -eq 0 ]]; then
        printf '%s\n' 'No URLs or file paths found in pane scrollback.' >&2
        return 0
    fi

    local selected key
    selected=$(printf '%s\n' "${items[@]}" | fzf \
        --multi \
        --exit-0 \
        --no-preview \
        --delimiter=$'\t' \
        --with-nth=1,2 \
        --expect=ctrl-y \
        --header='enter: open | ctrl-y: copy') || return 0

    key=$(head -1 <<< "$selected")
    selected=$(tail -n +2 <<< "$selected")
    [[ -z "$selected" ]] && return 0

    if [[ "$key" == "ctrl-y" ]]; then
        printf '%s\n' "$selected" | awk -F '\t' '{ print $2 }' | pbcopy
        return 0
    fi

    local type target line
    while IFS=$'\t' read -r type target line; do
        [[ -z "$target" ]] && continue
        case "$type" in
            URL)
                open "$target"
                ;;
            FILE)
                if [[ $(file -b --mime-type "$target") == image/* ]]; then
                    open "$target"
                    continue
                fi
                open_in_nvim "$herdr_bin" "$workspace_id" "$pane_path" "$target" "$line"
                ;;
        esac
    done <<< "$selected"
}

open_in_nvim() {
    local herdr_bin=$1 workspace_id=$2 cwd=$3 filepath=$4 line=$5
    local tab_json pane_id command
    tab_json=$("$herdr_bin" tab create --workspace "$workspace_id" --cwd "$cwd" --focus)
    pane_id=$(printf '%s' "$tab_json" | jq -er '.result.root_pane.pane_id')
    command="nvim"
    [[ -n "$line" ]] && command+=" +${line}"
    command+=" -- $(shell_quote "$filepath")"
    "$herdr_bin" pane run "$pane_id" "$command"
}

shell_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

main "$@"
