#!/usr/bin/env bash
set -euo pipefail

SRC="${1:-}"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/src/dotfiles}"
DEST_ROOT="$DOTFILES_DIR/home/.agents/skills"

if [[ -z "$SRC" ]]; then
  echo "Usage: sync-agent-skill <path-to-skill-dir>" >&2
  exit 1
fi

SRC="${SRC/#\~/$HOME}"

if [[ ! -d "$SRC" ]]; then
  echo "Source is not a directory: $SRC" >&2
  exit 1
fi

if [[ ! -f "$SRC/SKILL.md" ]]; then
  echo "Source does not look like a skill directory (missing SKILL.md): $SRC" >&2
  exit 1
fi

mkdir -p "$DEST_ROOT"
NAME="$(basename "$SRC")"
DEST="$DEST_ROOT/$NAME"

rm -rf "$DEST"
cp -a "$SRC" "$DEST"

echo "Synced skill to: $DEST"
echo "Next steps:"
echo "  cd $DOTFILES_DIR"
echo "  git status"
echo "  git add home/.agents/skills/$NAME"
echo "  git commit -m 'Add pi skill: $NAME'"
