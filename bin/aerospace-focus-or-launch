#!/usr/bin/env bash

set -euo pipefail

usage() {
    echo "Usage: aerospace-focus-or-launch APP_NAME [APP_BUNDLE_ID]" >&2
}

if [[ $# -lt 1 || $# -gt 2 ]]; then
    usage
    exit 2
fi

app_name=$1
app_bundle_id=${2:-}
aerospace_bin="${AEROSPACE_BIN:-/opt/homebrew/bin/aerospace}"

if [[ ! -x "$aerospace_bin" ]]; then
    echo "aerospace binary not found: $aerospace_bin" >&2
    exit 1
fi

window_id=""
if [[ -n "$app_bundle_id" ]]; then
    window_id=$("$aerospace_bin" list-windows --all --app-bundle-id "$app_bundle_id" --format '%{window-id}' | head -n 1)
fi

if [[ -z "$window_id" ]]; then
    window_id=$("$aerospace_bin" list-windows --all --format '%{window-id}	%{app-name}' \
        | awk -F '\t' -v app="$app_name" '$2 == app { print $1; exit }')
fi

if [[ -n "$window_id" ]]; then
    exec "$aerospace_bin" focus --window-id "$window_id"
fi

exec open -a "$app_name"
