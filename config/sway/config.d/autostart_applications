# Auth with polkit-gnome:
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

# Import environment variables for user systemd service manager, then bring up
# the session-bound daemons (way-displays, autotiling, swayfader — see
# config/systemd/user/). Chained so services never start before SWAYSOCK lands.
exec systemctl --user import-environment PATH DISPLAY WAYLAND_DISPLAY SWAYSOCK && \
     systemctl --user start sway-session.target

# Publish systemd user env (incl. mise shims from environment.d) to dbus-launched apps
exec hash dbus-update-activation-environment 2>/dev/null && \
     dbus-update-activation-environment --systemd PATH DISPLAY WAYLAND_DISPLAY SWAYSOCK

# Idle / sleep: one watcher only; lid suspend stays on logind.
exec swayidle -w \
    idlehint 1 \
    before-sleep "swaylock -f -c 000000"

# Media player priority (routes playerctl to last-active player)
exec playerctld daemon

# Desktop notifications
exec mako

# OSD for volume/brightness feedback
exec swayosd-server

# Start foot server
exec_always --no-startup-id foot --server

# cliphist
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store
     
# Network Applet
exec nm-applet --indicator

# Firewall Applet
exec sleep 2 && firewall-applet

# Welcome App
exec eos-welcome --startdelay=3

# nwg-drawer
exec_always nwg-drawer -r -c 7 -is 90 -mb 10 -ml 50 -mr 50 -mt 10

# Voice dictation
exec ~/.local/lib/handy/Handy.AppImage --start-hidden --no-tray
