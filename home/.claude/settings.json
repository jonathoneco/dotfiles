{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(shellcheck *)",
      "Bash(sway *)",
      "Bash(zsh -n *)",
      "Bash(nvim --headless *)",
      "Bash(python3 -c *)",
      "Bash(./validate.sh*)",
      "Bash(stow --no *)",
      "Bash(bn *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(mise *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(go get *)",
      "Bash(go mod *)",
      "Bash(go run *)",
      "Bash(go version*)",
      "Bash(gofmt *)",
      "Bash(mkdir -p *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(git push*)"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(sudo *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep '\\.go$' | xargs -r gofmt -w"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Serena MCP server available. Run /serena-activate to initialize semantic code navigation tools.'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -t 5000 'Claude Code' 'Needs your attention'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); if echo \"$FILE\" | grep -qE '(\\.env$|\\.env\\.)'; then echo 'Blocked: .env files cannot be edited by Claude' >&2; exit 2; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "documentation-generator@claude-code-templates": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "prompt-improver@severity1-marketplace": true
  },
  "extraKnownMarketplaces": {
    "severity1-marketplace": {
      "source": {
        "source": "github",
        "repo": "severity1/severity1-marketplace"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
