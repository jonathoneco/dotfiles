# Serena context engine — activate on session start
# Call serena.activate_project, serena.check_onboarding_performed and serena.initial_instructions

# Destructive operations — forbidden takes precedence over allow
prefix_rule(pattern=["git", "reset", "--hard"], decision="forbidden")
prefix_rule(pattern=["git", "push", "--force"], decision="forbidden")
prefix_rule(pattern=["rm", "-rf"], decision="forbidden")
prefix_rule(pattern=["sudo"], decision="forbidden")

# Git
prefix_rule(pattern=["git"], decision="allow")

# GitHub CLI
prefix_rule(pattern=["gh"], decision="allow")

# Beads
prefix_rule(pattern=["bd"], decision="allow")

# Go toolchain
prefix_rule(pattern=["go"], decision="allow")
prefix_rule(pattern=["gofmt"], decision="allow")

# Validation & linting
prefix_rule(pattern=["shellcheck"], decision="allow")
prefix_rule(pattern=["./validate.sh"], decision="allow")

# Shell & system
prefix_rule(pattern=["zsh"], decision="allow")
prefix_rule(pattern=["nvim"], decision="allow")
prefix_rule(pattern=["python3"], decision="allow")
prefix_rule(pattern=["mise"], decision="allow")
prefix_rule(pattern=["make"], decision="allow")
prefix_rule(pattern=["stow"], decision="allow")
prefix_rule(pattern=["sway"], decision="allow")
prefix_rule(pattern=["docker"], decision="allow")

# Safe utilities
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["head"], decision="allow")
prefix_rule(pattern=["tail"], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["which"], decision="allow")
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["grep"], decision="allow")
prefix_rule(pattern=["mkdir"], decision="allow")

