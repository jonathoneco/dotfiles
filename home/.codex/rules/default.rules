shot,fullPage:true}); results.push({route,status:resp?.status()??null,title,current,body:body.replace(/\\s+/g,' ').slice(0,180),screenshot:shot}); } for (const pair of [['/','root'],['/login','login'],['/pipeline','pipeline'],['/inbox','inbox'],['/scenarios','scenarios'],['/settings','settings']]) await visit(pair[0],pair[1]); console.log(JSON.stringify({timestamp:ts,bypassStatus:bypassResp.status,results,messages:messages.slice(0,20)},null,2)); await browser.close();\""], decision="allow")
