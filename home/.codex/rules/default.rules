prefix_rule(pattern=["node", "-e", "const { chromium } = require('playwright'); (async () => { const browser = await chromium.launch({ headless: true }); const page = await browser.newPage(); const logs = []; page.on('console', msg => logs.push(['console', msg.type(), msg.text()])); page.on('pageerror', err => logs.push(['pageerror', err.message])); const resp = await page.goto('https://wrangle-eight.vercel.app/pipeline', { waitUntil: 'networkidle', timeout: 30000 }); const bodyText = await page.locator('body').innerText({ timeout: 5000 }).catch(e => 'ERR:' + e.message); await page.screenshot({ path: 'output/playwright/vercel-prod-pipeline-auth-gated-20260429.png', fullPage: true }); console.log(JSON.stringify({ status: resp && resp.status(), url: page.url(), title: await page.title(), bodyText: bodyText.slice(0, 1000), logs }, null, 2)); await browser.close(); })().catch(e => { console.error(e); process.exit(1); });"], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "node -e \"const { chromium } = require('playwright'); (async () => { const browser = await chromium.launch({ headless: true }); const routes = ['/inbox', '/scenarios', '/settings']; const results = []; for (const route of routes) { const page = await browser.newPage(); const logs = []; page.on('console', msg => logs.push(['console', msg.type(), msg.text()])); page.on('pageerror', err => logs.push(['pageerror', err.message])); const resp = await page.goto('https://wrangle-eight.vercel.app' + route, { waitUntil: 'networkidle', timeout: 30000 }); const bodyText = await page.locator('body').innerText({ timeout: 5000 }).catch(e => 'ERR:' + e.message); await page.screenshot({ path: `output/playwright/vercel-prod${route.replaceAll('/', '-')}-auth-gated-20260429.png`, fullPage: true }); results.push({ route, status: resp && resp.status(), url: page.url(), bodyText: bodyText.slice(0, 500), logs }); await page.close(); } console.log(JSON.stringify(results, null, 2)); await browser.close(); })().catch(e => { console.error(e); process.exit(1); });\""], decision="allow")
prefix_rule(pattern=["node", "-e", "const { chromium } = require('playwright'); (async () => { const browser = await chromium.launch({ headless: true }); const routes = ['/inbox', '/scenarios', '/settings']; const results = []; for (const route of routes) { const page = await browser.newPage(); const logs = []; page.on('console', msg => logs.push(['console', msg.type(), msg.text()])); page.on('pageerror', err => logs.push(['pageerror', err.message])); const resp = await page.goto('https://wrangle-eight.vercel.app' + route, { waitUntil: 'networkidle', timeout: 30000 }); const bodyText = await page.locator('body').innerText({ timeout: 5000 }).catch(e => 'ERR:' + e.message); const file = 'output/playwright/vercel-prod' + route.split('/').join('-') + '-auth-gated-20260429.png'; await page.screenshot({ path: file, fullPage: true }); results.push({ route, status: resp && resp.status(), url: page.url(), bodyText: bodyText.slice(0, 500), logs, file }); await page.close(); } console.log(JSON.stringify(results, null, 2)); await browser.close(); })().catch(e => { console.error(e); process.exit(1); });"], decision="allow")
