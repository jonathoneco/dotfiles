prefix_rule(pattern=["jq", "[.[] | select(.fileId==\"k97bdwckmap0pebc2df8egtsbd86njbp\")] as $rows | {count: ($rows|length), totalCost: ($rows|map(.cost)|add), totalInputTokens: ($rows|map(.inputTokens // 0)|add), totalOutputTokens: ($rows|map(.outputTokens // 0)|add), failures: ($rows|map(select(.success != true))|length), byStage: ($rows|group_by(.stage)|map({stage: .[0].stage, count: length, cost: (map(.cost)|add), input: (map(.inputTokens // 0)|add), output: (map(.outputTokens // 0)|add)})|sort_by(-.cost)), byProvider: ($rows|group_by(.provider)|map({provider: .[0].provider, count: length, cost: (map(.cost)|add)}))}"], decision="allow")
prefix_rule(pattern=["jq", "[.[] | select(.fileId==\"k97bdwckmap0pebc2df8egtsbd86njbp\" and .documentId != null)] | group_by(.documentId) | map({documentId: .[0].documentId, count: length, cost: (map(.cost)|add), stages: (group_by(.stage)|map({stage: .[0].stage, count: length, cost: (map(.cost)|add)})|sort_by(.stage))}) | sort_by(-.cost)"], decision="allow")
prefix_rule(pattern=["jq", "[.[] | select(.fileId==\"k97bdwckmap0pebc2df8egtsbd86njbp\")] | map({_id, originalFilename, docTypeId, pageCount, status, source, created: ._creationTime, auditCount: (.audit|length), completedAt: (.audit[-1].timestamp // null)}) | sort_by(.created)"], decision="allow")
prefix_rule(pattern=["jq", "[.[] | select(.fileId==\"k97bdwckmap0pebc2df8egtsbd86njbp\" and .provider != \"anthropic\")]"], decision="allow")
prefix_rule(pattern=["mise", "exec", "--", "npx", "vercel"], decision="allow")
prefix_rule(pattern=["mise", "exec", "--", "npx", "convex", "logs"], decision="allow")
prefix_rule(pattern=["pkill"], decision="allow")
prefix_rule(pattern=["pgrep"], decision="allow")
prefix_rule(pattern=["kill"], decision="allow")
prefix_rule(pattern=["timeout", "20s", "mise", "exec", "--", "npx", "convex", "logs", "--success", "--history", "10000", "--jsonl"], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "CONVEX_DEPLOYMENT=dev:local mise exec -- npx convex codegen --typecheck disable"], decision="allow")
