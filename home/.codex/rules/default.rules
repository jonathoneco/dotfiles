prefix_rule(pattern=["node", "-e", "const {spawnSync}=require('node:child_process'); const vars=['WORKOS_CLIENT_ID','WRANGLE_LOCAL_TEST_AUTH','WRANGLE_LOCAL_TEST_AUTH_DEV_ONLY']; const env={...process.env,CONVEX_DEPLOYMENT:'prod:sincere-giraffe-916'}; for (const name of vars) { const r=spawnSync('npx',['convex','env','get',name],{encoding:'utf8',env}); const out=(r.stdout||'')+(r.stderr||''); const status=r.status===0?'present':out.includes('not found')?'absent':'error'; console.log(name+': '+status); if (status==='error') process.exitCode=1; }"], decision="allow")
prefix_rule(pattern=["node", "-e", "const {spawnSync}=require('node:child_process'); for (const deployment of ['prod:sincere-giraffe-916','prod:wrangle-prod']) { const env={...process.env,CONVEX_DEPLOYMENT:deployment}; const r=spawnSync('npx',['convex','env','get','WORKOS_CLIENT_ID'],{encoding:'utf8',env}); const out=(r.stdout||'')+(r.stderr||''); const status=r.status===0?'present':out.includes('not found')?'absent':'error'; console.log(deployment+': '+status); }"], decision="allow")
prefix_rule(pattern=["node", "-e", "const {spawnSync}=require('node:child_process'); const vars=['WORKOS_CLIENT_ID','GOOGLE_CLOUD_PROJECT_ID','GOOGLE_DOCAI_LOCATION','GOOGLE_DOCAI_PROCESSOR_ID','GOOGLE_SA_KEY_BASE64','ANTHROPIC_API_KEY','POSTMARK_SERVER_TOKEN','POSTMARK_SENDER_EMAIL','EMAIL_INBOUND_DOMAIN','INBOX_HASH_SALT','EMAIL_WEBHOOK_SECRET','SSN_HASH_SALT','WRANGLE_LOCAL_TEST_AUTH','WRANGLE_LOCAL_TEST_AUTH_DEV_ONLY']; const env={...process.env,CONVEX_DEPLOYMENT:'prod:sincere-giraffe-916'}; for (const name of vars) { const r=spawnSync('npx',['convex','env','get',name],{encoding:'utf8',env}); const out=(r.stdout||'')+(r.stderr||''); const status=r.status===0?'present':out.includes('not found')?'absent':'error'; console.log(name+': '+status); if (status==='error') process.exitCode=1; }"], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "node -e \"const {spawnSync}=require('node:child_process'); const fs=require('node:fs'); const file='/tmp/wrangle-vercel-prod-env-'+Date.now()+'.env'; const r=spawnSync('vercel',['env','pull',file,'--environment=production','--yes'],{encoding:'utf8'}); if (r.status!==0) { console.error('vercel env pull failed'); process.exit(r.status||1); } const text=fs.readFileSync(file,'utf8'); fs.rmSync(file,{force:true}); const parse=(s)=>Object.fromEntries(s.split(/\\n/).filter(l=>l&&!l.startsWith('#')).map(l=>{const i=l.indexOf('='); return i<0?[l,'']:[l.slice(0,i),l.slice(i+1).replace(/^\\\"|\\\"$/g,'')]})); const env=parse(text); const checks={VITE_CONVEX_URL:'https://sincere-giraffe-916.convex.cloud',VITE_WORKOS_REDIRECT_URI:'https://trywrangle.ai/callback'}; for (const [k,v] of Object.entries(checks)) console.log(k+': '+(env[k]===v?'matches expected':env[k]?'present but differs':'absent')); console.log('VITE_WORKOS_CLIENT_ID: '+(env.VITE_WORKOS_CLIENT_ID?'present':'absent'));\""], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "CONVEX_DEPLOYMENT=prod:sincere-giraffe-916 npx convex env remove WRANGLE_LOCAL_TEST_AUTH"], decision="allow")
