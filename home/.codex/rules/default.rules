prefix_rule(pattern=["node", "-e", "const {spawnSync}=require('node:child_process'); const variants=[['env','get','WORKOS_CLIENT_ID','--deployment','sincere-giraffe-916'],['env','get','WORKOS_CLIENT_ID','--deployment-name','sincere-giraffe-916'],['env','get','WORKOS_CLIENT_ID','--deployment','wrangle-prod'],['env','get','WORKOS_CLIENT_ID','--deployment-name','wrangle-prod']]; for (const args of variants) { const r=spawnSync('npx',['convex',...args],{encoding:'utf8',timeout:15000}); const out=(r.stdout||'')+(r.stderr||''); const status=r.status===0?'present':out.includes('not found')?'absent':'error'; const diagnostic=status==='error'?(' '+out.split('\\n').filter(Boolean).slice(0,1).join(' ').slice(0,120)):''; console.log(args.join(' ')+': '+status+diagnostic); }"], decision="allow")
