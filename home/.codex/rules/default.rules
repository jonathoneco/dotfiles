prefix_rule(pattern=["/usr/bin/zsh", "-lc", "node -e \"const {spawnSync}=require('node:child_process'); const vars=['WORKOS_CLIENT_ID','WRANGLE_LOCAL_TEST_AUTH','WRANGLE_LOCAL_TEST_AUTH_DEV_ONLY']; for (const name of vars) { const r=spawnSync('npx',['convex','env','get',name,'--deployment','wrangle-prod'],{encoding:'utf8'}); const out=(r.stdout||'')+(r.stderr||''); const status=r.status===0?'present':out.includes('not found')?'absent':'error'; console.log(`${name}: ${status}`); if (status==='error') process.exitCode=1; }\""], decision="allow")
