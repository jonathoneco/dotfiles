prefix_rule(pattern=["node", "-e", "const { chromium } = require(\"@playwright/test\"); const fs = require(\"node:fs\"); const path = require(\"node:path\"); (async()=>{ const base=\"https://wrangle-6gnlk59bj-richard-8523s-projects.vercel.app\"; const ts=new Date().toISOString().replace(/[-:]/g,\"\").replace(/\\.\\d+Z$/, \"Z\"); const dir=\"output/playwright\"; fs.mkdirSync(dir,{recursive:true}); const browser=await chromium.launch(); const page=await browser.newPage({viewport:{width:1365,height:900}}); const routes=[\"/\",\"/login\",\"/pipeline\",\"/inbox\",\"/scenarios\",\"/settings\"]; const errors=[]; page.on(\"pageerror\",e=>errors.push(\"pageerror \"+e.message)); page.on(\"console\",m=>{ if(m.type()===\"error\") errors.push(\"console \"+m.text()); }); for (const route of routes) { await page.goto(base+route,{waitUntil:\"networkidle\",timeout:30000}); const name=route===\"/\"?\"root\":route.slice(1).replace(/\\//g,\"-\"); const file=path.join(dir,\"vercel-staging-preview-\"+name+\"-unauth-\"+ts+\".png\"); await page.screenshot({path:file,fullPage:true}); const text=(await page.locator(\"body\").innerText({timeout:5000})).slice(0,300).replace(/\\s+/g,\" \"); console.log(route+\" -> \"+file+\" :: \"+text); } await page.goto(base+\"/login\",{waitUntil:\"networkidle\",timeout:30000}); await page.getByRole(\"button\", {name:/sign in/i}).click({timeout:10000}); await page.waitForLoadState(\"domcontentloaded\",{timeout:30000}).catch(()=>{}); await page.waitForTimeout(3000); const initFile=path.join(dir,\"vercel-staging-preview-workos-init-\"+ts+\".png\"); await page.screenshot({path:initFile,fullPage:true}); console.log(\"workos_url: \"+page.url()); console.log(\"workos_screenshot: \"+initFile); await browser.close(); if(errors.length){ console.log(\"browser errors:\"); for(const e of errors) console.log(e.slice(0,300)); process.exitCode=1; } })().catch(e=>{console.error(e); process.exit(1);});"], decision="allow")
