prefix_rule(pattern=["/usr/bin/zsh", "-lc", "node --input-type=module -e \"import { chromium } from '@playwright/test'; import fs from 'node:fs'; import path from 'node:path'; const env=fs.readFileSync('.env.e2e.local','utf8'); const secretLine=env.split(/\\r?\\n/).find(l=>l.startsWith('VERCEL_AUTOMATION_BYPASS_SECRET=')); if(!secretLine) throw new Error('Missing VERCEL_AUTOMATION_BYPASS_SECRET'); const secret=secretLine.slice('VERCEL_AUTOMATION_BYPASS_SECRET='.length).trim(); if(!secret) throw new Error('Empty VERCEL_AUTOMATION_BYPASS_SECRET'); const bypassResp=await fetch('https://staging.trywrangle.ai/',{redirect:'manual',headers:{'x-vercel-protection-bypass':secret,'x-vercel-set-bypass-cookie':'true'}}); const setCookie=bypassResp.headers.get('set-cookie') || ''; const match=setCookie.match(/_vercel_jwt=([^;]+)/); if(!match) throw new Error('Bypass did not return _vercel_jwt cookie; status '+bypassResp.status); const ts=new Date().toISOString().replace(/[-:]/g,'').replace(/\\.\\d{3}Z$/,'Z'); const out='output/playwright'; fs.mkdirSync(out,{recursive:true}); const browser=await chromium.launch({headless:true}); const context=await browser.newContext(); await context.addCookies([{name:'_vercel_jwt',value:match[1],domain:'staging.trywrangle.ai',path:'/',httpOnly:true,secure:true,sameSite:'Lax'}]); const page=await context.newPage(); const messages=[]; page.on('console', m => { if(['error','warning'].includes(m.type())) messages.push(m.type()+': '+m.text().slice(0,240)); }); page.on('pageerror', e => messages.push('pageerror: '+e.message.slice(0,240))); const results=[]; async function visit(route,label){ const url='https://staging.trywrangle.ai'+route; const resp=await page.goto(url,{waitUntil:'networkidle',timeout:45000}); const title=await page.title(); const current=page.url(); const body=(await page.locator('body').innerText({timeout:10000}).catch(()=>'')); const shot=path.join(out,'staging-trywrangle-cookie-bypass-'+label+'-'+ts+'.png'); await page.screenshot({path:shot,fullPage:true}); results.push({route,status:resp?.status()??null,title,current,body:body.replace(/\\s+/g,' ').slice(0,180),screenshot:shot}); } for (const pair of [['/','root'],['/login','login'],['/pipeline','pipeline'],['/inbox','inbox'],['/scenarios','scenarios'],['/settings','settings']]) await visit(pair[0],pair[1]); console.log(JSON.stringify({timestamp:ts,bypassStatus:bypassResp.status,results,messages:messages.slice(0,20)},null,2)); await browser.close();\""], decision="allow")
