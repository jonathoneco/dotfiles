prefix_rule(pattern=["/usr/bin/zsh", "-lc", "node -e \"const {spawnSync}=require('node:child_process'); const fs=require('node:fs'); const file='/tmp/wrangle-vercel-prod-env-'+Date.now()+'.env'; const r=spawnSync('vercel',['env','pull',file,'--environment=production','--yes'],{encoding:'utf8'}); if (r.status!==0) { console.error('vercel env pull failed'); process.exit(r.status||1); } const text=fs.readFileSync(file,'utf8'); fs.rmSync(file,{force:true}); const parse=(s)=>Object.fromEntries(s.split(/\\n/).filter(l=>l&&!l.startsWith('#')).map(l=>{const i=l.indexOf('='); return i<0?[l,'']:[l.slice(0,i),l.slice(i+1).replace(/^\\\"|\\\"$/g,'')]})); const env=parse(text); const checks={VITE_CONVEX_URL:'https://sincere-giraffe-916.convex.cloud',VITE_WORKOS_REDIRECT_URI:'https://trywrangle.ai/callback'}; for (const [k,v] of Object.entries(checks)) console.log(k+': '+(env[k]===v?'matches expected':env[k]?'present but differs':'absent')); console.log('VITE_WORKOS_CLIENT_ID: '+(env.VITE_WORKOS_CLIENT_ID?'present':'absent'));\""], decision="allow")
