prefix_rule(pattern=["node", "--input-type=module", "-e", "import { oneoffContext } from \"./node_modules/convex/dist/esm/bundler/context.js\"; import { getDeploymentSelection } from \"./node_modules/convex/dist/esm/cli/lib/deploymentSelection.js\"; import { loadSelectedDeploymentCredentials } from \"./node_modules/convex/dist/esm/cli/lib/api.js\"; import { deploymentDashboardUrlPage } from \"./node_modules/convex/dist/esm/cli/lib/dashboard.js\"; for (const ref of [\"wrangle-staging\",\"wrangle-prod\"]) { const ctx = await oneoffContext({url:undefined, adminKey:undefined, envFile:undefined}); const selection = await getDeploymentSelection(ctx, {url:undefined, adminKey:undefined, envFile:undefined, deployment:ref}); const creds = await loadSelectedDeploymentCredentials(ctx, selection, {ensureLocalRunning:false}); const fields = creds.deploymentFields; console.log(JSON.stringify({ref, deploymentName: fields?.deploymentName, deploymentType: fields?.deploymentType, url: creds.url, siteUrl: fields?.deploymentName ? `https://${fields.deploymentName}.convex.site` : undefined, dashboardUrl: fields?.deploymentName ? deploymentDashboardUrlPage(fields.deploymentName, \"\") : undefined})); }"], decision="allow")
