prefix_rule(pattern=["/usr/bin/zsh", "-lc", "node --input-type=module -e \"import { chromium } from '@playwright/test'; import fs from 'node:fs'; import path from 'node:path'; function loadEnv(file){const out={}; for(const raw of fs.readFileSync(file,'utf8').split(/\\r?\\n/)){const line=raw.trim(); if(!line||line.startsWith('#')) continue; const eq=line.indexOf('='); if(eq>0) out[line.slice(0,eq)]=line.slice(eq+1);} return out;} const e2e=loadEnv('.env.e2e.local'); const workos=loadEnv('.env.workos.local'); const bypass=e2e.VERCEL_AUTOMATION_BYPASS_SECRET; const email=workos.WORKOS_STAGING_TEST_EMAIL; const password=workos.WORKOS_STAGING_TEST_PASSWORD; if(!bypass||!email||!password) throw new Error('Missing required local smoke env'); const bypassResp=await fetch('https://staging.trywrangle.ai/',{redirect:'manual',headers:{'x-vercel-protection-bypass':bypass,'x-vercel-set-bypass-cookie':'true'}}); const jwt=(bypassResp.headers.get('set-cookie')||'').match(/_vercel_jwt=([^;]+)/)?.[1]; if(!jwt) throw new Error('No Vercel bypass cookie; status '+bypassResp.status); const ts=new Date().toISOString().replace(/[-:]/g,'').replace(/\\.\\d{3}Z$/,'Z'); const out='output/playwright'; fs.mkdirSync(out,{recursive:true}); const browser=await chromium.launch({headless:true}); const context=await browser.newContext(); await context.addCookies([{name:'_vercel_jwt',value:jwt,domain:'staging.trywrangle.ai',path:'/',httpOnly:true,secure:true,sameSite:'Lax'}]); const page=await context.newPage(); const messages=[]; page.on('console', m => { if(['error','warning'].includes(m.type())) messages.push(m.type()+': '+m.text().slice(0,260)); }); page.on('pageerror', e => messages.push('pageerror: '+e.message.slice(0,260))); async function shot(label){const p=path.join(out,'staging-auth-smoke-'+label+'-'+ts+'.png'); await page.screenshot({path:p,fullPage:true}); return p;} await page.goto('https://staging.trywrangle.ai/login',{waitUntil:'networkidle',timeout:45000}); const loginShot=await shot('login'); await page.getByRole('button',{name:/sign in/i}).click(); await page.waitForURL(/authkit\\.app/,{timeout:45000}); await page.waitForLoadState('domcontentloaded').catch(()=>{}); const authStartShot=await shot('authkit-start'); const emailInput=page.getByRole('textbox',{name:/email/i}).or(page.locator('input[type=email]')).first(); await emailInput.fill(email); await page.getByRole('button',{name:/continue/i}).click(); await page.waitForTimeout(1000); const passwordInput=page.locator('input[type=password]').first(); await passwordInput.waitFor({state:'visible',timeout:30000}); await passwordInput.fill(password); const authPasswordShot=await shot('authkit-password-filled'); await page.getByRole('button',{name:/sign in|continue/i}).click(); await page.waitForURL(url => url.toString().startsWith('https://staging.trywrangle.ai/'),{timeout:60000}); await page.waitForLoadState('networkidle',{timeout:45000}).catch(()=>{}); const afterUrl=page.url(); const afterBody=(await page.locator('body').innerText({timeout:15000}).catch(()=>'')); const afterShot=await shot('after-login'); const protectedResults=[]; for (const [route,label] of [['/pipeline','pipeline'],['/settings','settings']]) { const resp=await page.goto('https://staging.trywrangle.ai'+route,{waitUntil:'networkidle',timeout:45000}); const body=(await page.locator('body').innerText({timeout:15000}).catch(()=>'')); const screenshot=await shot('protected-'+label); protectedResults.push({route,status:resp?.status()??null,url:page.url(),body:body.replace(/\\s+/g,' ').slice(0,260),screenshot}); } console.log(JSON.stringify({timestamp:ts,bypassStatus:bypassResp.status,email,afterLogin:{url:afterUrl,body:afterBody.replace(/\\s+/g,' ').slice(0,260),screenshot:afterShot},screenshots:{login:loginShot,authkitStart:authStartShot,authkitPasswordFilled:authPasswordShot},protectedResults,messages:messages.slice(0,30)},null,2)); await browser.close();\""], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "node --input-type=module -e \"import { chromium } from '@playwright/test'; import fs from 'node:fs'; import path from 'node:path'; function loadEnv(file){const out={}; for(const raw of fs.readFileSync(file,'utf8').split(/\\r?\\n/)){const line=raw.trim(); if(!line||line.startsWith('#')) continue; const eq=line.indexOf('='); if(eq>0) out[line.slice(0,eq)]=line.slice(eq+1);} return out;} const e2e=loadEnv('.env.e2e.local'); const workos=loadEnv('.env.workos.local'); const bypass=e2e.VERCEL_AUTOMATION_BYPASS_SECRET; const email=workos.WORKOS_STAGING_TEST_EMAIL; const password=workos.WORKOS_STAGING_TEST_PASSWORD; if(!bypass||!email||!password) throw new Error('Missing required local smoke env'); const bypassResp=await fetch('https://staging.trywrangle.ai/',{redirect:'manual',headers:{'x-vercel-protection-bypass':bypass,'x-vercel-set-bypass-cookie':'true'}}); const jwt=(bypassResp.headers.get('set-cookie')||'').match(/_vercel_jwt=([^;]+)/)?.[1]; if(!jwt) throw new Error('No Vercel bypass cookie; status '+bypassResp.status); const ts=new Date().toISOString().replace(/[-:]/g,'').replace(/\\.\\d{3}Z$/,'Z'); const out='output/playwright'; fs.mkdirSync(out,{recursive:true}); const browser=await chromium.launch({headless:true}); const context=await browser.newContext(); await context.addCookies([{name:'_vercel_jwt',value:jwt,domain:'staging.trywrangle.ai',path:'/',httpOnly:true,secure:true,sameSite:'Lax'}]); const page=await context.newPage(); const messages=[]; page.on('console', m => { if(['error','warning'].includes(m.type())) messages.push(m.type()+': '+m.text().slice(0,260)); }); page.on('pageerror', e => messages.push('pageerror: '+e.message.slice(0,260))); async function shot(label){const p=path.join(out,'staging-auth-smoke-'+label+'-'+ts+'.png'); await page.screenshot({path:p,fullPage:true}); return p;} await page.goto('https://staging.trywrangle.ai/login',{waitUntil:'networkidle',timeout:45000}); const loginShot=await shot('login'); await page.getByRole('button',{name:/sign in/i}).click(); await page.waitForURL(/authkit\\.app/,{timeout:45000}); await page.waitForLoadState('domcontentloaded').catch(()=>{}); const authStartShot=await shot('authkit-start'); await page.locator('input[type=email], input[name=email]').first().fill(email); await page.locator('button[type=submit], button').filter({hasText:/continue|doorgaan/i}).first().click(); await page.locator('input[type=password]').first().waitFor({state:'visible',timeout:30000}); await page.locator('input[type=password]').first().fill(password); const authPasswordShot=await shot('authkit-password-filled'); await page.locator('button[type=submit]').first().click(); await page.waitForURL(url => url.toString().startsWith('https://staging.trywrangle.ai/'),{timeout:60000}); await page.waitForLoadState('networkidle',{timeout:45000}).catch(()=>{}); const afterUrl=page.url(); const afterBody=(await page.locator('body').innerText({timeout:15000}).catch(()=>'')); const afterShot=await shot('after-login'); const protectedResults=[]; for (const [route,label] of [['/pipeline','pipeline'],['/settings','settings']]) { const resp=await page.goto('https://staging.trywrangle.ai'+route,{waitUntil:'networkidle',timeout:45000}); const body=(await page.locator('body').innerText({timeout:15000}).catch(()=>'')); const screenshot=await shot('protected-'+label); protectedResults.push({route,status:resp?.status()??null,url:page.url(),body:body.replace(/\\s+/g,' ').slice(0,320),screenshot}); } console.log(JSON.stringify({timestamp:ts,bypassStatus:bypassResp.status,email,afterLogin:{url:afterUrl,body:afterBody.replace(/\\s+/g,' ').slice(0,320),screenshot:afterShot},screenshots:{login:loginShot,authkitStart:authStartShot,authkitPasswordFilled:authPasswordShot},protectedResults,messages:messages.slice(0,30)},null,2)); await browser.close();\""], decision="allow")
