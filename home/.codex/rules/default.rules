prefix_rule(pattern=["node", "-e", "const {spawnSync}=require('node:child_process'); const set=(name,value)=>{const rm=spawnSync('vercel',['env','rm',name,'preview','staging','--yes'],{encoding:'utf8'}); const add=spawnSync('vercel',['env','add',name,'preview','staging','--value',value,'--yes'],{encoding:'utf8'}); if(add.status!==0){console.error('failed '+name); console.error(((add.stdout||'')+(add.stderr||'')).split('\\n').filter(Boolean).slice(0,4).join('\\n')); process.exit(add.status||1);} console.log(name+': configured for Vercel Preview branch staging');}; set('VITE_CONVEX_URL','https://intent-firefly-366.convex.cloud'); set('VITE_WORKOS_CLIENT_ID','client_01KJ4AGY5RH86PV28WDVV9XVFV'); set('VITE_WORKOS_REDIRECT_URI','https://staging.trywrangle.ai/callback');"], decision="allow")
