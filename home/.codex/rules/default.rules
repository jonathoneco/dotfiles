prefix_rule(pattern=["/usr/bin/zsh", "-lc", "node --input-type=module -e \"import { chromium } from '@playwright/test'; import fs from 'node:fs'; import path from 'node:path'; const env=fs.readFileSync('.env.e2e.local','utf8'); const secretLine=env.split(/\\r?\\n/).find(l=>l.startsWith('VERCEL_AUTOMATION_BYPASS_SECRET=')); if(!secretLine) throw new Error('Missing VERCEL_AUTOMATION_BYPASS_SECRET'); const secret=secretLine.slice('VERCEL_AUTOMATION_BYPASS_SECRET='.length).trim(); const bypassResp=await fetch('https://staging.trywrangle.ai/',{redirect:'manual',headers:{'x-vercel-protection-bypass':secret,'x-vercel-set-bypass-cookie':'true'}}); const match=(bypassResp.headers.get('set-cookie')||'').match(/_vercel_jwt=([^;]+)/); if(!match) throw new Error('Bypass did not return cookie; status '+bypassResp.status); const ts=new Date().toISOString().replace(/[-:]/g,'').replace(/\\.\\d{3}Z$/,'Z'); const out='output/playwright'; fs.mkdirSync(out,{recursive:true}); const browser=await chromium.launch({headless:true}); const context=await browser.newContext(); await context.addCookies([{name:'_vercel_jwt',value:match[1],domain:'staging.trywrangle.ai',path:'/',httpOnly:true,secure:true,sameSite:'Lax'}]); const page=await context.newPage(); const messages=[]; page.on('console', m => { if(['error','warning'].includes(m.type())) messages.push(m.type()+': '+m.text().slice(0,240)); }); page.on('pageerror', e => messages.push('pageerror: '+e.message.slice(0,240))); await page.goto('https://staging.trywrangle.ai/login',{waitUntil:'networkidle',timeout:45000}); await Promise.all([page.waitForURL(url => !url.toString().startsWith('https://staging.trywrangle.ai/login'), {timeout:45000}).catch(()=>null), page.getByRole('button', {name:/sign in/i}).click()]); await page.waitForLoadState('domcontentloaded',{timeout:45000}).catch(()=>{}); const body=(await page.locator('body').innerText({timeout:10000}).catch(()=>'')); const shot=path.join(out,'staging-trywrangle-workos-init-'+ts+'.png'); await page.screenshot({path:shot,fullPage:true}); console.log(JSON.stringify({timestamp:ts,current:page.url(),title:await page.title(),body:body.replace(/\\s+/g,' ').slice(0,220),screenshot:shot,messages:messages.slice(0,20)},null,2)); await browser.close();\""], decision="allow")
